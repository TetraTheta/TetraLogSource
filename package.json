{
  "name": "tetralog",
  "private": true,
  "description": "TetraLog blog made with HB Cards Theme",
  "author": "TetraTheta",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @tetralog/cli run cli clean && hugo --gc --minify -e production && pnpm --filter @tetralog/cli run cli deslash",
    "check-update": "pnpm dlx npm-check-updates",
    "cli": "pnpm --filter @tetralog/cli run cli",
    "dev": "hugo server --renderToMemory --disableFastRender -D -p 44",
    "dev.prod": "hugo server --gc --minify --renderToMemory --disableFastRender -D -e production -p 44",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@popperjs/core": "^2.11.8",
    "autoprefixer": "^10.5.0",
    "bootstrap": "^5.3.8",
    "fuse.js": "^7.4.2",
    "highlight.js": "^11.11.1",
    "postcss-cli": "^11.0.1",
    "rtlcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.1"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "engines": {
    "npm": "Use pnpm instead of npm."
  }
}
