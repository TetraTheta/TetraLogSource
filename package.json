{
  "name": "tetralog",
  "private": true,
  "description": "TetraLog blog made with HB Cards Theme",
  "author": "TetraTheta",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @tetralog/cli run cli clean && hugo --gc --minify -e production && pnpm --filter @tetralog/cli run cli deslash",
    "check-update": "pnpm dlx npm-check-updates",
    "cli": "pnpm --filter @tetralog/cli run cli",
    "dev": "hugo server --renderToMemory --disableFastRender -D -p 44",
    "dev.prod": "hugo server --gc --minify --renderToMemory --disableFastRender -D -e production -p 44",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@popperjs/core": "^2.11.8",
    "autoprefixer": "^10.5.0",
    "bootstrap": "^5.3.8",
    "fuse.js": "^7.3.0",
    "postcss-cli": "^11.0.1",
    "rtlcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.3"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "engines": {
    "npm": "Use pnpm instead of npm."
  }
}
