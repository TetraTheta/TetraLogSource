{
  "name": "tetralog",
  "private": true,
  "description": "TetraLog blog made with HB Cards Theme",
  "author": "TetraTheta",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @tetralog/cli run cli clean && hugo --gc --minify -e production && pnpm --filter @tetralog/cli run cli deslash",
    "check-update": "pnpm dlx npm-check-updates",
    "cli": "pnpm --filter @tetralog/cli run cli",
    "dev": "hugo server --renderToMemory --disableFastRender -D -p 44",
    "dev.prod": "hugo server --gc --minify --renderToMemory --disableFastRender -D -e production -p 44",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@popperjs/core": "^2.11.8",
    "autoprefixer": "^10.5.0",
    "bootstrap": "^5.3.8",
    "fuse.js": "^7.4.1",
    "highlight.js": "^11.11.1",
    "postcss-cli": "^11.0.1",
    "rtlcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.60.1"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "engines": {
    "npm": "Use pnpm instead of npm."
  }
}
