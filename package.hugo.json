{
  "name": "tetralog",
  "private": true,
  "description": "TetraLog blog made with HB Cards Theme",
  "author": "TetraTheta",
  "type": "module",
  "scripts": {
    "build": "bun run cli clean && hugo --gc --minify -e production && bun run cli deslash",
    "check-update": "bun x --bun npm-check-updates",
    "cli": "bun run --bun ./.script/cli.ts",
    "dev": "hugo server --renderToMemory --disableFastRender -D -p 44",
    "dev.prod": "hugo server --gc --minify --renderToMemory --disableFastRender -D -e production -p 44"
  },
  "dependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "@popperjs/core": "^2.11.8",
    "autoprefixer": "^10.4.27",
    "bootstrap": "^5.3.8",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "fast-sort": "^3.4.1",
    "fuse.js": "^7.2.0",
    "html-minifier-terser": "^7.2.0",
    "minify-xml": "^4.5.2",
    "postcss-cli": "^11.0.1",
    "rtlcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.58.0"
  },
  "x-dependency-groups": {
    "theme": [
      "@fullhuman/postcss-purgecss",
      "@popperjs/core",
      "autoprefixer",
      "bootstrap",
      "fuse.js",
      "postcss-cli",
      "rtlcss"
    ],
    "app": [
      "cheerio",
      "commander",
      "fast-sort",
      "html-minifier-terser",
      "minify-xml"
    ]
  }
}
